{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update BlueBuild module digests in recipe files",
      "fileMatch": ["^recipes/.*\\.ya?ml$"],
      "matchStrings": [
        "(?<depName>ghcr\\.io/blue-build/[a-zA-Z0-9_-]+)@(?<currentDigest>sha256:[a-fA-F0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "currentValueTemplate": "latest"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/blue-build/**"],
      "schedule": ["before 5am on tuesday"],
      "groupName": "BlueBuild modules",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageTopic": "BlueBuild modules"
    }
  ]
}
